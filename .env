# PROJECT WARROOM Environment Configuration

# Application
PROJECT_NAME="PROJECT WARROOM"
VERSION="0.1.0"
ENVIRONMENT="development"
DEBUG=true

# PostgreSQL Database
DATABASE_URL=postgresql+asyncpg://warroom:warroom_secret_2024@localhost:5432/warroom
DATABASE_SYNC_URL=postgresql://warroom:warroom_secret_2024@localhost:5432/warroom
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=50
CACHE_TTL_SECONDS=300

# ChromaDB Vector Database
CHROMA_DB_URL=http://localhost:8000
CHROMA_DB_PATH=./data/chroma_db
CHROMA_COLLECTION_NAME=warroom_embeddings

# Ollama AI
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma3:latest
OLLAMA_TIMEOUT_SECONDS=60
OLLAMA_MAX_TOKENS=2048
OLLAMA_TEMPERATURE=0.7

# Embeddings
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_BATCH_SIZE=32
EMBEDDING_DIMENSION=384

# File Analysis
SUPPORTED_CODE_EXTENSIONS=.py,.js,.ts,.java,.cpp,.go,.rs,.rb,.php
SUPPORTED_DOC_EXTENSIONS=.md,.txt,.pdf,.pptx,.docx
MAX_FILE_SIZE_MB=10
MAX_FILES_PER_PROJECT=1000

# Analysis Configuration
HACKATHON_READINESS_THRESHOLD=75.0
ARCHITECTURE_RISK_THRESHOLD=25.0
INNOVATION_SCORE_THRESHOLD=80.0
TECHNICAL_DEBT_THRESHOLD=30.0
TEAM_READINESS_THRESHOLD=65.0

# Reporting
OUTPUT_DIR=./output
REPORT_FORMAT=pdf
REPORT_TEMPLATE_DIR=./reports/templates

# Testing
TEST_DATABASE_URL=postgresql+asyncpg://warroom:warroom_secret_2024@localhost:5432/warroom_test
TEST_REDIS_URL=redis://localhost:6379/1

# Performance
MAX_CONCURRENT_PROJECTS=10
ANALYSIS_TIMEOUT_SECONDS=300
WORKERS_COUNT=4

# Security
JWT_SECRET=warroom-jwt-secret-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
